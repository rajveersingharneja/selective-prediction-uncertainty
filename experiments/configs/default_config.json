{
  "seed": 42,
  "dataset": {
    "source": "synthetic",
    "n_samples": 20000,
    "fraud_ratio": 0.05,
    "test_size": 0.20,
    "val_size": 0.10,
    "apply_smote": false
  },
  "models": ["lr", "rf", "gb"],
  "calibrate": true,
  "selective_prediction": {
    "static_threshold": 0.70,
    "target_coverage": 0.80,
    "cost_fp": 1.0,
    "cost_fn": 5.0,
    "cost_abstain": 0.5,
    "cost_defer": 1.5,
    "tri_action": {
      "threshold_predict": 0.75,
      "threshold_defer": 0.55
    }
  },
  "distribution_shift": {
    "noise_stds": [0.0, 0.5, 1.0, 2.0],
    "imbalance_ratios": [0.05, 0.10, 0.20],
    "perturb_features": [0, 1, 2]
  }
}
